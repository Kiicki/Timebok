rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Hardkodet konfigurert admin-e-post (samme som ADMIN_EMAIL i
    // firebase-config.js). Må endres begge steder om admin-eposten endres.
    function isConfiguredAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'kulasic.igor@gmail.com';
    }

    // Brukerprofil:
    //   - create: eier kan opprette sin egen doc, MEN role='admin' tillates
    //     kun hvis e-posten matcher konfigurert admin.
    //   - update: eier kan oppdatere alt EKSPLISITT UNNTATT role-feltet.
    //     Admin (eksisterende) kan endre hva som helst.
    //   - delete: kun admin.
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());

      allow create: if isOwner(userId) && (
        request.resource.data.role == 'user' ||
        (request.resource.data.role == 'admin' && isConfiguredAdmin())
      );

      allow update: if isAdmin() || (
        isOwner(userId) && request.resource.data.role == resource.data.role
      );

      allow delete: if isAdmin();
    }

    // Subsamlinger (registrations, dayReceipts): eier (eller admin) har full
    // tilgang. Ingen role-felt her, så ingen restriksjoner.
    match /users/{userId}/{subcollection}/{document=**} {
      allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // Global data: alle innloggede kan LESE, kun admin kan SKRIVE.
    match /global/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
